    "expo-dev-client": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-animateable-text": "file:.yalc/react-native-animateable-text",
    "react-native-reanimated": "4.3.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.2.14",
    "typescript": "~6.0.3",
    "yalc": "^1.0.0-pre.53"
