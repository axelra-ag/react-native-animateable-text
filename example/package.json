{
  "name": "react-native-animateable-text-example",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "prebuild": "cd ../ && yalc publish && cd example && expo prebuild --clean && yarn",
